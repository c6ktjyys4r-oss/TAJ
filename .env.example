# TAJ Finance — Frontend Environment Variables
    # ─────────────────────────────────────────────────────────────────────────────
    # Copy this file to .env.local for local development.
    # .env.local is git-ignored; never commit real values.
    #
    # Vite only exposes variables prefixed with VITE_ to the browser bundle.
    # All other variables are available only to vite.config.ts (server-side).
    #
    # Production values are set in render.yaml or the Render dashboard.
    # ─────────────────────────────────────────────────────────────────────────────

    # Backend API base URL.
    # Development : point to the local API server (npm run dev inside server/)
    # Production  : injected automatically by Render (see render.yaml)
    VITE_API_URL=http://localhost:3000
    